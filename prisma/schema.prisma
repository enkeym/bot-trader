generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Идемпотентные намерения сделок (client id / ключ идемпотентности)
model OrderIntent {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique
  provider        String
  side            String
  status          String
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model TelegramUser {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  tonConnected Boolean  @default(false)
  accessPaid   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Singleton: автосимуляция по cron (вкл/выкл из Telegram)
model BotState {
  id                 String  @id @default("default")
  autoTradeEnabled   Boolean @default(false)
  /// Куда слать уведомления об авто-шаге (обычно chat id того, кто включил)
  notifyChatId       String?
  /// Учётная позиция BTC для режима BINANCE_SPOT_STRATEGY=roundtrip (только накопленное ботом)
  spotTrackedBtc     Decimal @default(0) @db.Decimal(18, 8)
  /// Средневзвешенная цена входа (USDT за 1 BTC); 0 если позиции нет
  spotAvgEntryUsdt   Decimal @default(0) @db.Decimal(18, 8)
  /// Макс. марк-цена с момента входа (для аварийного выхода от пика); 0 без позиции
  spotRoundtripPeakMarkUsdt Decimal @default(0) @db.Decimal(18, 8)
  updatedAt          DateTime @updatedAt
}
