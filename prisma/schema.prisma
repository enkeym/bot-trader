generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Идемпотентные намерения сделок (client id / ключ идемпотентности)
model OrderIntent {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique
  provider        String
  side            String
  status          String
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model TelegramUser {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  tonConnected Boolean  @default(false)
  accessPaid   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Singleton: автосимуляция по cron (вкл/выкл из Telegram)
model BotState {
  id                 String  @id @default("default")
  autoTradeEnabled   Boolean @default(false)
  /// Куда слать уведомления об авто-шаге (обычно chat id того, кто включил)
  notifyChatId       String?
  /// Учётный объём базового актива (SOL) в открытой roundtrip-позиции (накопленное ботом)
  spotTrackedBtc     Decimal @default(0) @db.Decimal(18, 8)
  /// Средневзвешенная цена входа в валюте котировки (USDT за 1 SOL); 0 если позиции нет
  spotAvgEntryUsdt   Decimal @default(0) @db.Decimal(18, 8)
  /// Макс. марк-цена с момента входа (для аварийного выхода от пика); 0 без позиции
  spotRoundtripPeakMarkUsdt Decimal @default(0) @db.Decimal(18, 8)
  /// Абсолютная цена активного трейлинг-стопа в валюте котировки; 0 — трейлинг не активирован
  spotTrailingStopUsdt Decimal @default(0) @db.Decimal(18, 8)
  /// Цена уровня take-profit для текущей позиции (для трейлинга и отображения)
  spotTpPriceUsdt    Decimal @default(0) @db.Decimal(18, 8)
  /// Цена уровня stop-loss для текущей позиции
  spotSlPriceUsdt    Decimal @default(0) @db.Decimal(18, 8)
  /// Время последнего успешного SELL, закрывшего учётную позицию (кулдаун перед следующим BUY)
  spotRoundtripLastSellAt DateTime?
  /// Отпечаток последних N убыточных SELL, для которых уже сработала пауза (переживает рестарт контейнера)
  lossStreakAckFingerprint String?
  /// До какого момента UTC действует пауза по серии убытков
  lossStreakPauseUntilAt   DateTime?
  updatedAt          DateTime @updatedAt
}
