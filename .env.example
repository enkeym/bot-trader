# Скопируйте в .env и заполните. Не коммитьте .env.

# --- обязательно ---
DATABASE_URL=postgresql://trader:trader@localhost:5432/trader
TELEGRAM_BOT_TOKEN=

# --- HTTP ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- Telegram (алерты и админы; через запятую) ---
TELEGRAM_ALERT_CHAT_ID=
# P2P-спред в чат каждые ~5 мин (не про Spot). Обычно не нужен: сделки шлются без этого.
# TELEGRAM_SPREAD_ALERTS_ENABLED=true
ADMIN_TELEGRAM_IDS=

# --- Redis (пусто = без Redis) ---
REDIS_URL=

# --- P2P-сигнал (только для фильтра спреда, не пара Spot) ---
# Binance P2P: стакан USDT за фиат. Для тестов с VPS/testnet чаще берут FIAT=USD (RUB с «чужого» IP часто пустой).
# Спред = насколько разъехались лучшие цены «купить USDT» и «продать USDT» на P2P.
# Spot-торговля — отдельно: BINANCE_SPOT_SYMBOL (ниже).
FIAT=USD
ASSET=USDT
MIN_SPREAD_PERCENT=0.15
MAX_NOTIONAL_USDT=500
DAILY_MAX_LOSS_USDT=50
# 0 = выкл. Лимит исполненных Spot-ордеров за сутки (UTC)
# MAX_DAILY_SPOT_TRADES=20
# N подряд убыточных Spot SELL → автоторговля ВЫКЛ (как ручное выключение) + уведомление (0 = выкл.)
# MAX_CONSECUTIVE_LOSS_SELLS=3
# UTC: часы 08:00–21:00 и только Пн–Пт (опционально; пусто = без фильтра)
# TRADING_WINDOW_UTC=08:00-21:00
# TRADING_DAYS_UTC=1-5
P2P_TAKER_FEE_PERCENT=0

# --- Binance Spot (без ключей — сигналы не исполняются). Testnet: testnet.binance.vision + ключи testnet ---
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Spot-пара (testnet: обычно SOLUSDT, BTCUSDT). USDTRUB есть только на mainnet и не на testnet.
BINANCE_SPOT_SYMBOL=SOLUSDT
BINANCE_SPOT_ORDER_SIDE=BUY
# Лимит MARKET BUY в USDT (если котировка пары — USDT)
BINANCE_SPOT_MAX_QUOTE_USDT=20
# Лимит MARKET BUY в RUB для пар вроде USDTRUB (если котировка — RUB)
BINANCE_SPOT_MAX_QUOTE_RUB=50000
BINANCE_SPOT_QUANTITY=0
# roundtrip: купить → продать с учётом позиции; fixed_side: только ORDER_SIDE
BINANCE_SPOT_STRATEGY=fixed_side
# --- Roundtrip TP (рекомендация под стоп ~1%): эффективный тейк = max(TAKE, MIN, ASSUMED_FEE) → 0.65% ---
BINANCE_SPOT_ROUNDTRIP_TAKE_PROFIT_PERCENT=0.65
BINANCE_SPOT_ROUNDTRIP_MIN_TAKE_PROFIT_PERCENT=0.35
BINANCE_SPOT_ASSUMED_ROUNDTRIP_FEE_PERCENT=0.22
# Следующий шаг (после стабильной статистики 1–2 недели): TAKE=1.0, MIN=0.45 (MIN не выше TAKE); комиссии подправить под факт Binance
# Не торговать, если free базы на бирже и учёт tracked расходятся сильнее N % (0 = выкл.)
# BINANCE_SPOT_BALANCE_DIVERGENCE_MAX_PCT=3
# BINANCE_SPOT_ROUNDTRIP_STOP_LOSS_PERCENT=1.0
# BINANCE_SPOT_ROUNDTRIP_MAX_POSITION_USDT=200
# Лимит учётной позиции в RUB для USDTRUB (0 = выкл.)
# BINANCE_SPOT_ROUNDTRIP_MAX_POSITION_RUB=0
# только для roundtrip: true = докупать каждый сигнал; иначе ждать продажи
# BINANCE_SPOT_ROUNDTRIP_ACCUMULATE=true
# Аварийный выход: продажа, если марк упал на N % от пика с момента входа (0 = выкл.)
# BINANCE_SPOT_ROUNDTRIP_EMERGENCY_DRAWDOWN_PERCENT=3
# Не открывать BUY при высокой волатильности / перегреве (0 = выкл.; σ в п.п. по 1h за 24h)
# BINANCE_SPOT_SKIP_BUY_VOLATILITY_STDDEV_GT=0.5
# BINANCE_SPOT_SKIP_BUY_CHANGE_24H_GT=8
# Не BUY при падении за 24h ниже −N % (порог отрицательный, 0 = выкл.):
# BINANCE_SPOT_SKIP_BUY_CHANGE_24H_LT=-1.5
# То же по 7 дням (168h), затяжной даунтренд:
# BINANCE_SPOT_SKIP_BUY_CHANGE_168H_LT=-5
# Пауза перед новым BUY после полного выхода SELL (мс), 0 = выкл.:
# BINANCE_SPOT_BUY_COOLDOWN_AFTER_SELL_MS=300000
# Не покупать у локального хая: окно часов (≤24 → сутки, ≤168 → неделя, иначе 30d) + мин. откат от макс. high в окне, %:
# BINANCE_SPOT_BUY_PULLBACK_WINDOW_HOURS=24
# BINANCE_SPOT_BUY_MIN_PULLBACK_FROM_HIGH_PCT=0.12
# Уменьшать размер BUY при высокой σ: BINANCE_SPOT_QUOTE_VOLATILITY_SCALE=true
# BINANCE_SPOT_QUOTE_VOLATILITY_REF_STDDEV_PP=0.2
# BINANCE_SPOT_QUOTE_VOLATILITY_MIN_SCALE=0.25

# Кэш публичных свечей для /market и фильтров (сек)
# MARKET_STATS_CACHE_TTL_SEC=120
# Символ для свечей /market (пусто = BINANCE_SPOT_SYMBOL). На testnet нет USDTRUB — поставьте BTCUSDT.
# MARKET_STATS_SYMBOL=BTCUSDT
# Запасной символ, если основной даёт Invalid symbol (по умолчанию BTCUSDT)
# MARKET_STATS_FALLBACK_SYMBOL=BTCUSDT

# --- /stats: «прибыль от старта» — оценка счёта в валюте котировки пары до бота (опционально) ---
# STATS_EQUITY_BASELINE_USDT=10000
# При заданной базе — пауза автоторговли, если эквити просело ниже baseline более чем на N % (0 = выкл.)
# AUTO_TRADE_MAX_EQUITY_DRAWDOWN_PERCENT=15

# --- автоторговля (мс) ---
AUTO_TRADE_INTERVAL_MS=180000

# Docker Compose подставляет POSTGRES_* из .env — см. docker-compose.yml
