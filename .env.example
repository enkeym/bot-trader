# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
PORT=3000
# Порт на хосте для сервиса bot-trader в docker-compose (проброс на контейнер)
APP_PORT=3000

# Пароль БД в Docker (согласуйте с docker-compose, если меняете)
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader
POSTGRES_DB=trader

# Локально (npm на хосте, БД в Docker):
DATABASE_URL=postgresql://trader:trader@localhost:5432/trader
# В Docker Compose URL задаётся в docker-compose.yml — не перезаписывайте localhost-ом.
# Опционально. Если пусто — бот работает без Redis. Если задано — нужен `docker compose up -d redis`
REDIS_URL=

# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Binance — только при DRY_RUN=false и реальных вызовах SAPI; минимальные права
BINANCE_API_KEY=
BINANCE_API_SECRET=

# P2P / исполнение
DRY_RUN=true
EXECUTION_MODE=AUTO_EXCHANGE_ONLY
P2P_PROVIDER=binance

# Стратегия (USDT/RUB)
FIAT=RUB
ASSET=USDT
MIN_SPREAD_PERCENT=0.15
MAX_NOTIONAL_USDT=500
DAILY_MAX_LOSS_USDT=50

# Комиссии (проценты, для расчёта чистого спреда)
P2P_TAKER_FEE_PERCENT=0.0

# TON Connect (Mini App / deep link)
TON_CONNECT_MANIFEST_URL=https://example.com/tonconnect-manifest.json
TON_PAYMENT_RECIPIENT=

# Опционально: ограничить доступ к командам после «оплаты» в TON
REQUIRE_TON_ACCESS=false

# Публичный URL приложения (для ссылок /connect)
PUBLIC_BASE_URL=http://localhost:3000

# Опционально: chat id для алертов по спреду (cron)
TELEGRAM_ALERT_CHAT_ID=

# Список telegram user id админов (через запятую), обход REQUIRE_TON_ACCESS и /autotrade
ADMIN_TELEGRAM_IDS=

# Интервал авто-симуляции (мс), см. /autotrade
AUTO_TRADE_INTERVAL_MS=180000

# Стартовый виртуальный баланс для /stats (USDT)
PAPER_WALLET_START_USDT=10000
