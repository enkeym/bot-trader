# Скопируйте в .env и заполните. Не коммитьте .env.

# --- обязательно ---
DATABASE_URL=postgresql://trader:trader@localhost:5432/trader
TELEGRAM_BOT_TOKEN=

# --- HTTP ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- Telegram (алерты и админы; через запятую) ---
TELEGRAM_ALERT_CHAT_ID=
ADMIN_TELEGRAM_IDS=

# --- Redis (пусто = без Redis) ---
REDIS_URL=

# --- Binance Spot (без ключей Spot-ордера не отправляются) ---
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SPOT_SYMBOL=SOLUSDT
# Лимит MARKET BUY в USDT на один ордер (сайзинг по риску может снизить ниже)
BINANCE_SPOT_MAX_QUOTE_USDT=20
BINANCE_SPOT_MAX_QUOTE_RUB=50000
# Лимит стоимости открытой позиции (USDT). 0 = выкл.
BINANCE_SPOT_ROUNDTRIP_MAX_POSITION_USDT=200
# Аварийный выход: падение марка от пика с момента входа на N % (0 = выкл.)
BINANCE_SPOT_ROUNDTRIP_EMERGENCY_DRAWDOWN_PERCENT=3
# Расхождение free базы и tracked: блокируем SELL при сильном расхождении (0 = выкл.)
BINANCE_SPOT_BALANCE_DIVERGENCE_MAX_PCT=3
# Cooldown после полного выхода SELL перед следующим BUY (мс)
BINANCE_SPOT_BUY_COOLDOWN_AFTER_SELL_MS=600000

# --- Риск-менеджмент ---
# Верхний потолок notional на сделку (USDT); реальный размер меньше, если SL широкий
MAX_NOTIONAL_USDT=20
# Дневной стоп по убытку (USDT). 0 = выкл.
DAILY_MAX_LOSS_USDT=50
# Пауза после серии убыточных SELL (N SELL подряд; 0 = выкл.)
MAX_CONSECUTIVE_LOSS_SELLS=5
LOSS_STREAK_COOLDOWN_MS=1800000
# Макс. число исполненных Spot за сутки UTC (0 = выкл.)
# MAX_DAILY_SPOT_TRADES=0
# Комиссия taker на одну сторону, % (Binance Spot по умолчанию 0.1)
SPOT_TAKER_FEE_PERCENT=0.1
# Риск на сделку как % от эквити: notional ≈ (equity × RISK%) / SL%
RISK_PER_TRADE_PERCENT=1
# Минимальная чистая прибыль TP сверх 2× комиссии (%)
MIN_NET_TP_PERCENT=0.3
# Нижняя граница notional ордера (USDT) — дополнительная защита
MIN_ORDER_NOTIONAL_USDT=10

# --- ATR-стратегия (тренд-фолловинг 1h + подтверждение 4h) ---
ATR_PERIOD=14
ATR_SL_MULT=1.0
ATR_TP_MULT=2.0
ATR_TRAIL_ACTIVATION_MULT=1.0
ADX_MIN=20
EMA_FAST=20
EMA_SLOW=50
EMA_LONG=200
RSI_ENTRY_MIN=40
RSI_ENTRY_MAX=65
SWING_LOOKBACK_4H=12

# --- Gemini 1.5 Flash (опционально, бесплатный тариф) ---
# GEMINI_ENABLED=true
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash-latest
# GEMINI_MIN_CONFIDENCE=60
# GEMINI_CACHE_MS=600000

# --- Расписание торговли (UTC; пусто = 24/7) ---
# TRADING_WINDOW_UTC=08:00-21:00
# TRADING_DAYS_UTC=1-5

# --- /stats: «прибыль от старта» (оценка счёта в USDT до бота, опционально) ---
# STATS_EQUITY_BASELINE_USDT=10000
AUTO_TRADE_MAX_EQUITY_DRAWDOWN_PERCENT=15

# --- Тайминги ---
AUTO_TRADE_INTERVAL_MS=180000
# Кэш свечей для /market и регим-фильтра (сек, мин 30)
# MARKET_STATS_CACHE_TTL_SEC=120
# Fallback-символ, если основной даёт Invalid symbol на testnet
# MARKET_STATS_FALLBACK_SYMBOL=BTCUSDT

EXECUTION_MODE=AUTO_EXCHANGE_ONLY
