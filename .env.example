# Скопируйте в .env и заполните. Не коммитьте .env.

# --- обязательно ---
DATABASE_URL=postgresql://trader:trader@localhost:5432/trader
TELEGRAM_BOT_TOKEN=

# --- HTTP ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- Telegram (алерты и админы; через запятую) ---
TELEGRAM_ALERT_CHAT_ID=
ADMIN_TELEGRAM_IDS=

# --- Redis (пусто = без Redis) ---
REDIS_URL=

# --- режим: true = только запись в БД, без ордеров на бирже ---
DRY_RUN=true

# --- P2P-сигнал (спред): валюта фиата и пороги ---
FIAT=USD
ASSET=USDT
MIN_SPREAD_PERCENT=0.15
MAX_NOTIONAL_USDT=500
DAILY_MAX_LOSS_USDT=50
P2P_TAKER_FEE_PERCENT=0

# --- Binance Spot (при DRY_RUN=false). Testnet: ключи с testnet.binance.vision + BASE_URL ниже ---
BINANCE_SPOT_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SPOT_SYMBOL=BTCUSDT
BINANCE_SPOT_ORDER_SIDE=BUY
BINANCE_SPOT_MAX_QUOTE_USDT=20
BINANCE_SPOT_QUANTITY=0
# roundtrip: купить → продать с учётом позиции; fixed_side: только ORDER_SIDE
BINANCE_SPOT_STRATEGY=fixed_side
BINANCE_SPOT_ROUNDTRIP_TAKE_PROFIT_PERCENT=0.15
# только для roundtrip: true = докупать каждый сигнал; иначе ждать продажи
# BINANCE_SPOT_ROUNDTRIP_ACCUMULATE=true

# --- автоторговля (мс) ---
AUTO_TRADE_INTERVAL_MS=180000

# Docker Compose подставляет POSTGRES_* из .env — см. docker-compose.yml
